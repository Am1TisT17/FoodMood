# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated list of allowed origins (Vite default = http://localhost:5173)
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/foodmood

# JWT
JWT_SECRET=change-me-to-a-long-random-string-please
JWT_EXPIRES_IN=7d

# OCR microservice
OCR_SERVICE_URL=http://localhost:4100

# ML microservice (recipe recommender). If unset, backend uses rule-based fallback.
ML_SERVICE_URL=http://localhost:4200
ML_TIMEOUT_MS=8000
ML_INTERNAL_KEY=local-dev-key

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
